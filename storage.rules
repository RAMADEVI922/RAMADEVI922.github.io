rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Menu item images - read by everyone, write by authenticated users
    match /menuItems/{itemId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Category banner images - read by everyone, write by authenticated users
    match /categoryBanners/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
